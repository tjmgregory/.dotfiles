	name:         test-<INST>
	uuid:         12345678-1234-1234-1234-123456789abc
	state:        running
	image:        nginx
	resources:
	  memory:     128MiB
	  vcpus:      1
	volumes:
	- test-<VOL>:/mnt
	networks:
	- uuid:       12345678-1234-1234-1234-123456789abc
	  private-ip: 10.X.X.X
	  mac:        aa:bb:cc:dd:ee:ff
