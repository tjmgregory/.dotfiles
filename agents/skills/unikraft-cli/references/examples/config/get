$ unikraft config get

stdout:
	path:           /tmp/TestGolden/001/config.yaml
	profile:        default
	profiles:
	- name:         default
	  type:         cloud
	  token:        <token>
	  organization: test
	  metros:
	  - name:       test
	    endpoint:   https://api.unikraft.test
	    country:    xx
	    insecure:   false

$ unikraft config get -o json

stdout:
	[
	  {
	    "path": "/tmp/TestGolden/001/config.yaml",
	    "profile": "default",
	    "profiles": {
	      "default": {
	        "control-plane": "",
	        "insecure": false,
	        "metros": [
	          {
	            "country": "xx",
	            "endpoint": "https://api.unikraft.test",
	            "insecure": false,
	            "name": "test"
	          }
	        ],
	        "name": "default",
	        "organization": "test",
	        "token": "<token>",
	        "type": "cloud"
	      }
	    }
	  }
	]

$ unikraft config get -o yaml

stdout:
	- path: /tmp/TestGolden/001/config.yaml
	  profile: default
	  profiles:
	    default:
	      control-plane: ""
	      insecure: false
	      metros:
	      - country: xx
	        endpoint: https://api.unikraft.test
	        insecure: false
	        name: test
	      name: default
	      organization: test
	      token: <token>
	      type: cloud
