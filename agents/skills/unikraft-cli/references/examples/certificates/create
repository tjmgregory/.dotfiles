$ unikraft certificate list

stdout:
	METRO  NAME  COMMON-NAME  STATE  CREATED  NOT-AFTER

$ unikraft certificate create --set name=test-$UNIQ_CERT_A --set cn=$CERT_A_CN --set chain=$CERT_A_CHAIN --set pkey=$CERT_A_KEY --set metro=test

stdout:
	metro:         test
	name:          test-<CERT_A>
	uuid:          12345678-1234-1234-1234-123456789abc
	common-name:   <CERT_A_CN>
	subject:       CN=<CERT_A_CN>
	issuer:        CN=<CERT_A_CN>
	serial-number: 01
	state:         valid
	timestamps:
	  created:     RELATIVE_TIME
	  not-before:  RELATIVE_TIME
	  not-after:   RELATIVE_TIME

$ unikraft certificate create --set name=test-$UNIQ_CERT_B --set cn=$CERT_B_CN --set chain=$CERT_B_CHAIN --set pkey=$CERT_B_KEY --set metro=test

stdout:
	metro:         test
	name:          test-<CERT_B>
	uuid:          12345678-1234-1234-1234-123456789abc
	common-name:   <CERT_B_CN>
	subject:       CN=<CERT_B_CN>
	issuer:        CN=<CERT_B_CN>
	serial-number: 01
	state:         valid
	timestamps:
	  created:     RELATIVE_TIME
	  not-before:  RELATIVE_TIME
	  not-after:   RELATIVE_TIME

$ unikraft certificate list

stdout:
	METRO  NAME               COMMON-NAME                                STATE  CREATED   NOT-AFTER
	test   test-<CERT_B>  <CERT_B_CN>  valid  RELATIVE_TIME  RELATIVE_TIME
	test   test-<CERT_A>  <CERT_A_CN>  valid  RELATIVE_TIME  RELATIVE_TIME

