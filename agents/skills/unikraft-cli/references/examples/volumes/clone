$ unikraft volume create --output quiet --set name=test-$UNIQ_VOLUME --set size=10 --set metro=test

stdout:
	test/test-<VOLUME>

$ unikraft volume clone test-$UNIQ_VOLUME --output quiet --set name=test-$UNIQ_VOLUME_CLONE

stdout:
	test/test-<VOLUME_CLONE>

$ unikraft volume inspect test-$UNIQ_VOLUME test-$UNIQ_VOLUME_CLONE

stdout:
	metro:        test
	name:         test-<VOLUME>
	uuid:         12345678-1234-1234-1234-123456789abc
	state:        available
	size:         10MiB
	filesystem:   virtiofs
	quota-policy: static
	persistent:   true
	timestamps:
	  created:    RELATIVE_TIME

	metro:        test
	name:         test-<VOLUME_CLONE>
	uuid:         12345678-1234-1234-1234-123456789abc
	state:        available
	size:         10MiB
	filesystem:   virtiofs
	quota-policy: static
	persistent:   true
	timestamps:
	  created:    RELATIVE_TIME

$ unikraft volume delete test-$UNIQ_VOLUME test-$UNIQ_VOLUME_CLONE

stdout:
	test-<VOLUME>
	test-<VOLUME_CLONE>
