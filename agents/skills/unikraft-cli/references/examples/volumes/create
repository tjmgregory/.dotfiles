$ unikraft volume list

stdout:
	METRO  NAME  STATE  SIZE  CREATED

$ unikraft volume create --set name=test-$UNIQ_VOLUME --set size=10 --set metro=test

stdout:
	metro:        test
	name:         test-<VOLUME>
	uuid:         12345678-1234-1234-1234-123456789abc
	state:        available
	size:         10MiB
	filesystem:   virtiofs
	quota-policy: static
	persistent:   true
	timestamps:
	  created:    RELATIVE_TIME

$ unikraft volume list

stdout:
	METRO  NAME               STATE      SIZE   CREATED
	test   test-<VOLUME>  available  10MiB  RELATIVE_TIME

$ unikraft volume inspect test-$UNIQ_VOLUME

stdout:
	metro:        test
	name:         test-<VOLUME>
	uuid:         12345678-1234-1234-1234-123456789abc
	state:        available
	size:         10MiB
	filesystem:   virtiofs
	quota-policy: static
	persistent:   true
	timestamps:
	  created:    RELATIVE_TIME

$ unikraft volume delete test-$UNIQ_VOLUME

stdout:
	test-<VOLUME>
