$ unikraft volume wait --help

stdout:
	Wait for volumes to match a filter.

	Usage:
	  unikraft volumes wait --until=UNTIL <target> ... [flags]

	Arguments:
	  <target> ...
	          Target volumes to wait for.

	Fields:
	  metro
	  name
	  uuid
	  tags
	  state
	  size
	  filesystem
	  quota-policy
	  persistent
	  timestamps, timestamps.created
	  attached-to, attached-to.*, attached-to.*.name, attached-to.*.uuid
	  mounted-by, mounted-by.*, mounted-by.*.name, mounted-by.*.uuid, mounted-
	  by.*.read-only

	Flags:
	      --until, --filter
	          Filter expression to wait for (e.g. --until state==running).
	      --interval
	          Polling interval.
	          [default: 2s]
	      --timeout
	          Timeout before giving up.
	          [default: 0]
	  -f, --field
	          Specify which fields to include in the output.
	  -o, --output
	          Output format. One of: kv, table, json, yaml, raw, quiet, template.

	Global flags:
	  -h, --help
	          Show context-sensitive help.
	      --config=<file> ($UNIKRAFT_CONFIG)
	          Path to the configuration file.
	      --log-level=<level> ($UNIKRAFT_LOG_LEVEL)
	          Set the logging level.
	          [default: info, choices: trace, debug, info, warn, error, fatal]
	      --log-type=<type> ($UNIKRAFT_LOG_TYPE)
	          Set the log type.
	          [default: text, choices: text, json]
	      --profile=<name> ($UNIKRAFT_PROFILE)
	          Set the current profile.
	      --[no-]telemetry ($UNIKRAFT_TELEMETRY)
	          Toggle anonymous usage analytics.
	          [default: true]

$ unikraft volume create --help

stdout:
	Create a volume.

	Usage:
	  unikraft volumes create [flags]

	Examples:
	  # Create a new volume
	  unikraft volume create \
	  	  --name demo-volume \
	  	  --size 10 \
	  	  --metro fra

	Fields:
	  metro
	  name
	  uuid
	  tags
	  state
	  size
	  filesystem
	  quota-policy
	  persistent
	  timestamps, timestamps.created
	  attached-to, attached-to.*, attached-to.*.name, attached-to.*.uuid
	  mounted-by, mounted-by.*, mounted-by.*.name, mounted-by.*.uuid, mounted-
	  by.*.read-only

	Flags:
	      --set=<name>=<value>, --set-file=<name>=<filename>
	          Key-value pairs to set on the volume.
	      --visual
	          Open an editor to modify fields visually.
	      --cmd
	          Run a command to edit fields (receives YAML on stdin, outputs edited YAML on stdout).
	      --load, --save=<FILE>
	          Load fields from a YAML file.
	      --dry-run
	          Print patches without applying them.
	  -f, --field
	          Specify which fields to include in the output.
	  -o, --output
	          Output format. One of: kv, table, json, yaml, raw, quiet, template.

	Global flags:
	  -h, --help
	          Show context-sensitive help.
	      --config=<file> ($UNIKRAFT_CONFIG)
	          Path to the configuration file.
	      --log-level=<level> ($UNIKRAFT_LOG_LEVEL)
	          Set the logging level.
	          [default: info, choices: trace, debug, info, warn, error, fatal]
	      --log-type=<type> ($UNIKRAFT_LOG_TYPE)
	          Set the log type.
	          [default: text, choices: text, json]
	      --profile=<name> ($UNIKRAFT_PROFILE)
	          Set the current profile.
	      --[no-]telemetry ($UNIKRAFT_TELEMETRY)
	          Toggle anonymous usage analytics.
	          [default: true]

	Create flags:
	      --metro=<metro>
	          Metro to create in.
	          [examples: fra, sfo, nyc]
	  -n, --name=<name>
	          Volume name.
	      --size=<size>
	          Volume size.
	          [examples: 10GiB, 100MiB]
	      --filesystem=<filesystem>
	          Volume filesystem.
	          [example: ext4]
	      --quota-policy=<quota-policy>
	          Volume quota policy.
	          [examples: static, dynamic]

$ unikraft volume clone --help

stdout:
	Clone a volume.

	Usage:
	  unikraft volumes clone <source> [flags]

	Arguments:
	  <source>
	          Name or UUID of the volume to clone.

	Examples:
	  # Clone a volume with a new name
	  unikraft volume clone demo-volume --name demo-volume-clone

	Flags:
	      --set=<name>=<value>, --set-file=<name>=<filename>
	          Key-value pairs to set on the volume.
	  -f, --field
	          Specify which fields to include in the output.
	  -o, --output
	          Output format. One of: kv, table, json, yaml, raw, quiet, template.

	Global flags:
	  -h, --help
	          Show context-sensitive help.
	      --config=<file> ($UNIKRAFT_CONFIG)
	          Path to the configuration file.
	      --log-level=<level> ($UNIKRAFT_LOG_LEVEL)
	          Set the logging level.
	          [default: info, choices: trace, debug, info, warn, error, fatal]
	      --log-type=<type> ($UNIKRAFT_LOG_TYPE)
	          Set the log type.
	          [default: text, choices: text, json]
	      --profile=<name> ($UNIKRAFT_PROFILE)
	          Set the current profile.
	      --[no-]telemetry ($UNIKRAFT_TELEMETRY)
	          Toggle anonymous usage analytics.
	          [default: true]

	flag-clone
	  -n, --name=<name>
	          New volume name.
	      --tags=<tag>
	          Volume tags.
	          [examples: env=prod, team=platform]

$ unikraft volume edit --help

stdout:
	Edit a volume.

	Usage:
	  unikraft volumes edit <target> [flags]

	Arguments:
	  <target>
	          Target volume to edit.

	Examples:
	  # Resize a volume
	  unikraft volume edit demo-volume --size 20

	Fields:
	  metro
	  name
	  uuid
	  tags
	  state
	  size
	  filesystem
	  quota-policy
	  persistent
	  timestamps, timestamps.created
	  attached-to, attached-to.*, attached-to.*.name, attached-to.*.uuid
	  mounted-by, mounted-by.*, mounted-by.*.name, mounted-by.*.uuid, mounted-
	  by.*.read-only

	Flags:
	      --set=<name>=<value>, --set-file=<name>=<filename>
	          Key-value pairs to set on the volume.
	      --add=<name>=<value>, --add-file=<name>=<filename>
	          Key-value pairs to add to the volume.
	      --del=<name>=<value>, --del-file=<name>=<filename>
	          Keys to delete from the volume.
	      --visual
	          Open an editor to modify fields visually.
	      --cmd
	          Run a command to edit fields (receives YAML on stdin, outputs edited YAML on stdout).
	      --load, --save=<FILE>
	          Load fields from a YAML file.
	      --dry-run
	          Print patches without applying them.
	  -f, --field
	          Specify which fields to include in the output.
	  -o, --output
	          Output format. One of: kv, table, json, yaml, raw, quiet, template.

	Global flags:
	  -h, --help
	          Show context-sensitive help.
	      --config=<file> ($UNIKRAFT_CONFIG)
	          Path to the configuration file.
	      --log-level=<level> ($UNIKRAFT_LOG_LEVEL)
	          Set the logging level.
	          [default: info, choices: trace, debug, info, warn, error, fatal]
	      --log-type=<type> ($UNIKRAFT_LOG_TYPE)
	          Set the log type.
	          [default: text, choices: text, json]
	      --profile=<name> ($UNIKRAFT_PROFILE)
	          Set the current profile.
	      --[no-]telemetry ($UNIKRAFT_TELEMETRY)
	          Toggle anonymous usage analytics.
	          [default: true]

	Edit flags:
	      --size=<size>
	          Volume size.
	          [examples: 20GiB, 100MiB]
	      --quota-policy=<quota-policy>
	          Volume quota policy.
	          [examples: static, dynamic]

$ unikraft volume delete --help

stdout:
	Remove a volume.

	Usage:
	  unikraft volumes delete [<target> ...] [flags]

	Arguments:
	  [<target> ...]
	          Target volumes to remove.

	Examples:
	  # Delete a volume by name or UUID
	  unikraft volume delete demo-volume

	Fields:
	  metro
	  name
	  uuid
	  tags
	  state
	  size
	  filesystem
	  quota-policy
	  persistent
	  timestamps, timestamps.created
	  attached-to, attached-to.*, attached-to.*.name, attached-to.*.uuid
	  mounted-by, mounted-by.*, mounted-by.*.name, mounted-by.*.uuid, mounted-
	  by.*.read-only

	Flags:
	      --all
	          Remove all volumes. Prompts for confirmation.
	      --filter
	          Filter volumes to remove (e.g. --filter state==running). Prompts for confirmation.
	      --force
	          Do not prompt for confirmation when using --all or --filter.
	  -f, --field
	          Specify which fields to include in the output.
	  -o, --output
	          Output format. One of: kv, table, json, yaml, raw, quiet, template.

	Global flags:
	  -h, --help
	          Show context-sensitive help.
	      --config=<file> ($UNIKRAFT_CONFIG)
	          Path to the configuration file.
	      --log-level=<level> ($UNIKRAFT_LOG_LEVEL)
	          Set the logging level.
	          [default: info, choices: trace, debug, info, warn, error, fatal]
	      --log-type=<type> ($UNIKRAFT_LOG_TYPE)
	          Set the log type.
	          [default: text, choices: text, json]
	      --profile=<name> ($UNIKRAFT_PROFILE)
	          Set the current profile.
	      --[no-]telemetry ($UNIKRAFT_TELEMETRY)
	          Toggle anonymous usage analytics.
	          [default: true]
